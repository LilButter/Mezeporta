{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Mezeporta",
    "version": "1.5.2"
  },
  "tauri": {
    "bundle": {
      "identifier": "com.Mezeporta.app"
    },
    "allowlist": {
      "all": true
    },
    "security": {
      "csp": null,
      "dangerousUseHttpScheme": true
    },
    "updater": {
      "active": false
    },
    "windows": []
  }
}
